{
  "name": "@mcbroken/mcau",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prepare:prisma": "rm -rf generated/prisma && mkdir -p generated && cp -R ../../packages/database/generated/prisma generated/",
    "dev": "pnpm prepare:prisma && serverless offline start",
    "check:updates": "npx npm-check-updates",
    "check:updates:u": "npx npm-check-updates -u && pnpm i",
    "deploy:staging": "pnpm prepare:prisma && SLS_STAGE=staging serverless deploy --stage staging",
    "deploy:production": "pnpm prepare:prisma && SLS_STAGE=production serverless deploy --stage production",
    "check-types": "tsc --noEmit",
    "lint": "eslint '**/*.ts'",
    "lint:fix": "eslint '**/*.ts' --fix",
    "invoke": "pnpm prepare:prisma && serverless invoke local --function",
    "package": "pnpm prepare:prisma && serverless package"
  },
  "devDependencies": {
    "@mcbroken/eslint-config": "workspace:*",
    "@mcbroken/serverless-config": "workspace:*",
    "@mcbroken/typescript-config": "workspace:*",
    "@serverless/typescript": "^3.38.0",
    "typescript": "^5.9.2",
    "eslint": "^9.39.1"
  },
  "dependencies": {
    "@mcbroken/mclogik": "workspace:*"
  }
}
